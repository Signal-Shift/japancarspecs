# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Cursor — project/agent config and local IDE state (never commit)
.cursor/
.cursorrules

# Claude Code — local settings, sessions, hooks (never commit)
.claude/

# AI assistant instruction files at repo root (never commit)
CLAUDE.md
claude.md
AGENTS.md
agents.md

# GitHub ruleset JSON payloads (apply via gh api / UI; keep local)
.github/rulesets/
