# Copy to .env.local for local development.

# Relative to the prisma/ folder (creates prisma/dev.db).
DATABASE_URL="file:./dev.db"
# Required in production. Optional locally if you omit it (a dev fallback exists, but set a real secret for anything shared).
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST="true"
# Optional; Auth.js infers from request when unset in dev
# AUTH_URL="http://localhost:3000"

# Stripe (Billing / metered usage webhooks)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Report gateway (future). Not used until backend is integrated.
# REPORT_GATEWAY_URL=""
